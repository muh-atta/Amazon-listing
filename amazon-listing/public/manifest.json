{
  "manifest_version": 3,
  "name": "Amazon Listing Extension",
  "version": "1.0",
  "description": "Chrome extension for amazon listing page",
  "action": {
      "default_icon": "logo.jpg",
      "default_popup": "index.html"
    },
    "permissions": ["tabs", "scripting", "activeTab", "downloads", "storage", "sidePanel"],
"host_permissions": [
    "<all_urls>"
],
"side_panel": {
    "default_path": "sidebar.html"
},
    "background": {
        "service_worker": "background.js"
    },
    "content_scripts": [
        {
            "matches": ["*://www.amazon.com/*"],
            "js": ["amazonScrapper.js"]
        }
    ]
}