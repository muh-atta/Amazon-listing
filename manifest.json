{
  "manifest_version": 3,
  "name": "Amazon Listing Extension",
  "version": "1.0",
  "description": "Chrome extension for amazon listing page",
  "action": {
      "default_icon": "logo.jpg",
      "default_popup": "popup.html"
    },
    "content_scripts": [
        {
            "matches": ["<all_urls>"],
            "js": ["content.js"]
        }
    ]
}